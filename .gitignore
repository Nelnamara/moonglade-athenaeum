# ---- Secrets / dev-only files: NEVER commit ----
token.txt
.env
config.json
serve.txt
serve.log

# ---- Private dev notes: reverse-engineering ledger, internal maps. NEVER publish ----
private/

# ---- Gallery server generated files ----
pixai_backup/gallery/

# ---- Any --out directory's generated files, by name, not just the default `pixai_backup/`.
# `pixai_backup/` below only matches THAT literal name; a custom `--out my_dir` doesn't
# match it, so its catalog.db/images/gallery/etc. would otherwise show up in git status.
# These are unanchored (no leading slash) so they catch the same well-known out_dir-
# relative structure at any depth, regardless of the out_dir's name -- same trick
# jobs.jsonl already used below (before this, jobs.jsonl was the ONLY thing generalized
# this way; catalog.db and the rest still leaked under a custom --out).
catalog.db
catalog.csv
gallery/
images/
videos/
imported/
_duplicates/
organize_manifest.csv
audit_report.csv
verify_report.csv
raw_tasks.jsonl

# ---- Job activity log (append-only registry the Jobs card reads; runtime state) ----
# pixai_backup/ is already ignored below; these catch any out_dir that lands in the repo.
jobs.jsonl
jobs.jsonl.tmp

# ---- Personal output: your images, prompts, catalogs ----
# Contains your generated images, prompt text, and dates. Keep out of git.
pixai_backup/
*.webp
# Uncomment if you ever keep loose exports in the repo root and want them ignored:
# *.png
# *.jpg
# *.jpeg

# ---- Python ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ---- Working dashboard artifact (Claude+owner reference; not project documentation) ----
docs/DASHBOARD.html

# ---- Loom Node toolchain (loom/package.json) ----
loom/node_modules/

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Stray artifact: a root file literally named HEAD, content just "OUTPUT".
# Real cause (found 2026-07-22): tests/test_panel.py's ffmpeg-mocking FakeProc
# patches subprocess.Popen globally with no command guard, and create_app()
# shells `git rev-parse --short HEAD` through that same patched Popen -- for
# THAT call argv[-1] is the literal string "HEAD". Fixed at the source (the
# FakeProc now only writes when argv[0] == "ffmpeg"); this stays as a backstop
# in case it ever regenerates some other way. Anchored to root so it never
# shadows .git/HEAD or subdir HEADs. ----
/HEAD

# ---- Claude Code: local browser-preview launch config (machine-local dev-server
# definition, points at a local port). Scoped to the file, not all of .claude/, so
# genuinely shareable project config (agents, hooks) can still be tracked later. ----
/.claude/launch.json

# Ephemeral design mockups: throwaway single-file HTML built to verify a design
# before implementing it (the locked pixel source lives in the Claude artifact, not
# here). Never committed -- they would rot instantly against the real surface.
static/_mockup_*.html

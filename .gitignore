# ---- Secrets / dev-only files: NEVER commit ----
token.txt
.env
config.json
pixai_gui_settings.json
serve.txt
serve.log

# ---- Private dev notes: reverse-engineering ledger, internal maps. NEVER publish ----
private/

# ---- Gallery server generated files ----
pixai_backup/gallery/

# ---- Job activity log (append-only registry the Jobs card reads; runtime state) ----
# pixai_backup/ is already ignored below; these catch any out_dir that lands in the repo.
jobs.jsonl
jobs.jsonl.tmp

# ---- Personal output: your images, prompts, catalogs ----
# Contains your generated images, prompt text, and dates. Keep out of git.
pixai_backup/
*.webp
# Uncomment if you ever keep loose exports in the repo root and want them ignored:
# *.png
# *.jpg
# *.jpeg

# ---- Python ----
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# ---- Working dashboard artifact (Claude+owner reference; not project documentation) ----
docs/DASHBOARD.html

# ---- Loom Node toolchain (loom/package.json) ----
loom/node_modules/

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Stray artifact: a root file literally named HEAD (born from a `> HEAD` shell
# redirect; content is just "OUTPUT"). Anchored to root so it never shadows .git/HEAD
# or subdir HEADs. This neutralizes it no matter which machine regenerates it. ----
/HEAD

# ---- Claude Code: local browser-preview launch config (machine-local dev-server
# definition, points at a local port). Scoped to the file, not all of .claude/, so
# genuinely shareable project config (agents, hooks) can still be tracked later. ----
/.claude/launch.json

# Ephemeral design mockups: throwaway single-file HTML built to verify a design
# before implementing it (the locked pixel source lives in the Claude artifact, not
# here). Never committed -- they would rot instantly against the real surface.
static/_mockup_*.html
